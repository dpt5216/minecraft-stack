# Caddyfile — auto-TLS for the tutorial site
# Minecraft TCP (:25565) is exposed directly by the game-server container;
# Caddy only handles web traffic here.

minecraft.dthasno.website {
    root * /srv/www
    templates
    file_server
    encode gzip zstd

    # Security headers
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        Referrer-Policy "strict-origin-when-cross-origin"
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        Content-Security-Policy "default-src 'self'; img-src 'self' data:; style-src 'self' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self'; frame-src https://www.youtube.com; child-src https://www.youtube.com"
    }

    log {
        output file /var/log/caddy/access.log
    }
}
