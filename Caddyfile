# Caddyfile — auto-TLS for the tutorial site
# Minecraft TCP (:25565) is exposed directly by the game-server container;
# Caddy only handles web traffic here.

minecraft.dthasno.website {
    root * /srv/www
    file_server
    encode gzip zstd

    # Security headers
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        Referrer-Policy "strict-origin-when-cross-origin"
    }

    log {
        output file /var/log/caddy/access.log
    }
}
