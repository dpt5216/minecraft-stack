# Normalize line endings — LF in the repo, LF on checkout
# Prevents CRLF from creeping in on Windows checkouts
* text=auto eol=lf

# Shell scripts must always be LF (bash -n fails on CRLF)
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.properties text eol=lf
*.txt text eol=lf
Caddyfile text eol=lf
